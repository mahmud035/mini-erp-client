# Base URL of the Mini ERP backend API (no trailing slash).
# Same-origin `/api` in every environment: prod goes through the Vercel rewrite,
# dev through the Vite proxy below. Copy this file to .env for local runs.
VITE_API_URL=/api

# Dev only: upstream the Vite dev-server proxies `/api` to (mirrors the Vercel
# rewrite). Override to point local dev at a different backend. Unused in prod.
VITE_DEV_PROXY_TARGET=https://mini-erp-server.up.railway.app

# Raw Railway origin (NO `/api`, NO trailing slash) for the DIRECT low-stock
# WebSocket — WebSockets can't ride the `/api` rewrite, so the socket connects
# cross-origin and authenticates with the in-memory access token. Set the same
# value in Vercel's env for prod.
VITE_SOCKET_URL=https://mini-erp-server.up.railway.app
